# Frontend (Vite) environment — safe, non-secret values only.
# Copy this file to .env and fill in your Discord Client ID.

# Your Discord application's Client ID (NOT the secret)
VITE_DISCORD_CLIENT_ID=your_client_id_here

# Must match the redirect URI registered in the Discord dashboard
# and DISCORD_REDIRECT_URI in server/.env
VITE_DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord/callback
