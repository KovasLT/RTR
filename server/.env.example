# Discord OAuth credentials (server-side ONLY — never commit the real .env)
# Copy this file to server/.env and fill in your values from
# https://discord.com/developers/applications  ->  your app  ->  OAuth2

DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here

# Must EXACTLY match a redirect URI registered in the Discord dashboard
# and the VITE_DISCORD_REDIRECT_URI used by the frontend.
DISCORD_REDIRECT_URI=http://localhost:5173/auth/discord/callback

# Where the frontend runs (used for CORS)
CLIENT_ORIGIN=http://localhost:5173

# Port this auth server listens on (Vite proxies /api here)
PORT=3001
